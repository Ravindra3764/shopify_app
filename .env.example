# Tenant config template (white-label). Copy to `.env` and fill per tenant/flavor.
#   cp .env.example .env
# `.env` is gitignored; this template is safe to commit. Do NOT put real
# tokens here. Storefront access tokens are public-scope, but keep them out
# of source control anyway.

# --- Branding ---
APP_NAME=My Store
FONT_FAMILY=Monorope

# --- Shopify Storefront API ---
SHOPIFY_DOMAIN=your-store.myshopify.com
STOREFRONT_ACCESS_TOKEN=your_storefront_access_token
STOREFRONT_API_VERSION=2026-04

# --- Brand colors (only PRIMARY varies per tenant in practice) ---
PRIMARY_COLOR="#086C4C"
SECONDARY_COLOR="#625B71"
ACCENT_COLOR="#7D5260"

# --- Assets ---
LOGO_ASSET=Address of the logo

# --- Feature flags ---
WISHLIST_ENABLED=true
# Read reviews from `product_review` metaobjects (Storefront). Individual
# reviews show when the store defines that metaobject; otherwise the aggregate
# rating still renders.
REVIEWS_ENABLED=false
# Submitting reviews needs a write provider (Storefront API is read-only).
REVIEW_SUBMISSION_ENABLED=false
# true = shoppers can only review products they've purchased; false = any
# signed-in shopper can review any product.
REVIEW_ONLY_PURCHASED=false
# Judge.me review provider. Set BOTH to route reviews (read + submit) through
# Judge.me; leave blank to read Storefront `product_review` metaobjects only.
# WARNING: JUDGEME_API_TOKEN is a PRIVATE (read/write) token — shipping it in
# the app exposes it. Only enable when the tenant accepts that risk.
JUDGEME_SHOP_DOMAIN=
JUDGEME_API_TOKEN=
SEARCH_ENABLED=true
# Suggested search chips shown on the search screen (comma-separated).
POPULAR_SEARCHES=Sunglasses,Overcoat,Scarf,Blazer,Accessories

# Wishlist onboarding: one-time hint shown on first launch. Text is tenant-
# configurable; set the enable flag to false to suppress it entirely.
WISHLIST_DOUBLE_TAP_HINT_ENABLED=true
WISHLIST_HINT_TEXT=Double-tap any product to save it to your wishlist.
# true = replay the hint on every launch (demo/QA); false = show it once.
WISHLIST_HINT_ALWAYS=false

#! Checkout (white-label toggles)
# Guest checkout: when false, checkout is gated behind sign-in.
GUEST_CHECKOUT_ENABLED=true
#? Save & reuse multiple delivery addresses locally.
CHECKOUT_ADDRESS_BOOK_ENABLED=true
# Offer a promo-code entry during checkout.
CHECKOUT_PROMO_CODES_ENABLED=true
# Surface tenant-advertised promo codes as a one-tap "Available offers" banner
# at checkout (independent of the manual entry field above). Offers are read
# from `promo_offer` metaobjects in Shopify Admin (Storefront-exposed) — no
# static list here. See lib/shopify/queries/promo_queries.dart.
CHECKOUT_PROMO_OFFERS_ENABLED=true
# In-app WebView checkout gives the app the completion redirect (the only
# reliable proof of a paid order). External browser gives no completion signal.
CHECKOUT_IN_APP_WEBVIEW_ENABLED=true
# Require a phone number on the delivery address form.
CHECKOUT_PHONE_REQUIRED=true
# Product detail style: true = Blinkit-style draggable sheet (partial preview,
# expand-to-full, horizontal swipe between siblings); false = classic page.
PRODUCT_DETAIL_SHEET_ENABLED=true
# Tenant home country (ISO 3166-1 alpha-2) prefilled on the address form.
DEFAULT_COUNTRY=IN

# Static content pages (Profile → More). Privacy policy + Terms of service
# come from Settings → Policies automatically (no config). About / Help are
# Online Store → Pages — set each page's handle here, or leave blank to hide
# that tile. e.g. a page at /pages/about-us has handle "about-us".
ABOUT_PAGE_HANDLE=
HELP_PAGE_HANDLE=
